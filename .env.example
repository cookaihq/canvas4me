# ============================================================================
# canvas4me - docker-compose 运行时环境变量
# ----------------------------------------------------------------------------
# 复制为 .env 后按需修改:
#   cp .env.example .env
# ============================================================================

# Docker 对外暴露的端口(外层 nginx / caddy 反代到这个端口)
# 默认 3183;如该端口被占,改成 8080 / 8088 等任意可用端口
CANVAS4ME_PORT=3183
